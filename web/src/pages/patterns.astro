---
import Base from "@layouts/Base.astro";
import { PatternsInsights } from "@components/islands/PatternsInsights";
import patternsData from "../../public/data/patterns.json";
import type { Patterns } from "@/lib/types/aggregates";
import { getT, currentNavPath } from "@/i18n/astro";
import { defaultLocale, type Locale } from "@/i18n/config";

const patterns = patternsData as Patterns;
const buildTime = new Date().toISOString().slice(11, 16);
const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const current = currentNavPath(Astro.url.pathname);
const t = getT(locale);
---

<Base
  title={t("patterns.page_title")}
  current={current}
  lastUpdated={buildTime}
  locale={locale}
>
  <main class="space-y-6 px-4 sm:px-6 lg:px-8 py-8">
    <header>
      <p class="font-mono text-[10px] tracking-[0.2em] text-fg-subtle uppercase">
        {t("patterns.header_kicker")}
      </p>
      <h1 class="mt-2 font-display text-3xl leading-tight text-fg sm:text-4xl">
        {t("patterns.header_title")}
      </h1>
      <p class="mt-1 font-sans text-sm text-fg-muted sm:text-base">
        {t("patterns.header_subtitle")}
      </p>
    </header>
    <PatternsInsights client:load patterns={patterns} locale={locale} />
  </main>
</Base>
