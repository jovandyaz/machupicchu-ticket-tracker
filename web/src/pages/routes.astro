---
import Base from "@layouts/Base.astro";
import { RoutesComparison } from "@components/islands/RoutesComparison";
import type { RouteStats } from "@/lib/types/aggregates";
import { getT, currentNavPath } from "@/i18n/astro";
import { defaultLocale, type Locale } from "@/i18n/config";

const routeFiles = import.meta.glob<RouteStats>(
  "../../public/data/routes/*.json",
  { eager: true, import: "default" },
);
const routes: RouteStats[] = Object.values(routeFiles);
const buildTime = new Date().toISOString().slice(11, 16);
const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const current = currentNavPath(Astro.url.pathname);
const t = getT(locale);
---

<Base
  title={t("routes.page_title")}
  current={current}
  lastUpdated={buildTime}
  locale={locale}
>
  <main class="space-y-6 px-4 sm:px-6 lg:px-8 py-8">
    <header>
      <p class="font-mono text-[10px] tracking-[0.2em] text-fg-subtle uppercase">
        {t("routes.header_kicker")}
      </p>
      <h1 class="mt-2 font-display text-3xl leading-tight text-fg sm:text-4xl">
        {t("routes.header_title")}
      </h1>
      <p class="mt-1 font-sans text-sm text-fg-muted sm:text-base">
        {t("routes.header_subtitle")}
      </p>
    </header>
    <RoutesComparison client:load routes={routes} locale={locale} />
  </main>
</Base>
